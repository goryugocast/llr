{
  "name": "obsidian-llr-plugin",
  "version": "0.1.2",
  "description": "LLR: Live Life Recording system for Obsidian.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "dev:sync": "OBSIDIAN_SYNC_ON_BUILD=1 node esbuild.config.mjs",
